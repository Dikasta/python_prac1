Find the maximum profit from stock prices:
 
def max_profit(prices: List[int]) -> int:
    min_price = float('inf')
    max_profit = 0
    for price in prices:
        if price < min_price:
            min_price = price
        elif price - min_price > max_profit:
            max_profit = price - min_price
    return max_profit
# Test case
print(max_profit([7,1,5,3,6,4]))  # Output: 5
